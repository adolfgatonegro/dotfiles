#!/usr/bin/env bash
# gatoneg.ro

# niri-rof

# This script will parse the currently open windows in niri, and look for one
# that matches the app-id given as the first argument. If a window is found,
# focus will be moved to it. Otherwise, a command will be executed.

# When multiple matching windows exist, focus will move to the oldest one (the
# first matching Window ID).

if [ $# -ne 2 ]; then
	echo "Usage: niri-rof <app-id> <command>"
	exit 1
fi

app_id="$1"
command="$2"

# Check if a matching window ID exists
window_id=$(niri msg windows | awk -v app_id="$app_id" '
	{
	    prev_prev_line = prev_line
	    prev_line = curr_line
	    curr_line = $0
	}
	$0 ~ "App ID: \"" app_id "\"" {
	    split(prev_prev_line, fields, " ")
	    print substr(fields[3], 1, length(fields[3])-1)
	}
' | head -n1)

# Focus the window or run a command
if [ -n "$window_id" ]; then
	niri msg action focus-window --id "$window_id"
else
	bash -c "$command" &
fi
